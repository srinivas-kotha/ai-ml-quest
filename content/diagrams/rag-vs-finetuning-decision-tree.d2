# RAG vs Fine-Tuning vs Prompt Engineering Decision Tree
# AI/ML Quest - Chapter 1: Production RAG Pipeline

direction: down

vars: {
  d2-config: {
    theme-id: 200
    dark-theme-id: 200
  }
}

classes: {
  decision: {
    shape: diamond
    style: {
      fill: "#2d2550"
      stroke: "#ffb800"
      stroke-width: 2
      font-color: "#ffffff"
      font-size: 14
      border-radius: 8
    }
  }
  start: {
    shape: rectangle
    style: {
      fill: "#ffb800"
      stroke: "#ffb800"
      font-color: "#1c1535"
      font-size: 16
      bold: true
      border-radius: 12
    }
  }
  leaf-rag: {
    shape: rectangle
    style: {
      fill: "#1a4a2e"
      stroke: "#4ade80"
      stroke-width: 2
      font-color: "#e2e8f0"
      font-size: 13
      border-radius: 12
    }
  }
  leaf-ft: {
    shape: rectangle
    style: {
      fill: "#4a1a3d"
      stroke: "#f472b6"
      stroke-width: 2
      font-color: "#e2e8f0"
      font-size: 13
      border-radius: 12
    }
  }
  leaf-pe: {
    shape: rectangle
    style: {
      fill: "#1a3a4a"
      stroke: "#38bdf8"
      stroke-width: 2
      font-color: "#e2e8f0"
      font-size: 13
      border-radius: 12
    }
  }
  leaf-hybrid: {
    shape: rectangle
    style: {
      fill: "#4a3a1a"
      stroke: "#ffb800"
      stroke-width: 2
      font-color: "#e2e8f0"
      font-size: 13
      border-radius: 12
    }
  }
  badge: {
    shape: rectangle
    style: {
      fill: "#3d3560"
      stroke: "#8a8aa8"
      font-color: "#c4c4dc"
      font-size: 11
      border-radius: 8
    }
  }
}

# Start node
start: "Need to improve LLM output?" {
  class: start
}

# First decision
d1: "Need external or\ndynamic knowledge?" {
  class: decision
}

start -> d1: {
  style: {
    stroke: "#8a8aa8"
    stroke-width: 2
  }
}

# YES branch - external knowledge needed
d2: "How often does\ndata change?" {
  class: decision
}

d1 -> d2: "Yes" {
  style: {
    stroke: "#4ade80"
    stroke-width: 2
    font-color: "#4ade80"
    font-size: 13
    bold: true
  }
}

# Frequency branches
rag: |md
  ## RAG
  Best when: knowledge base changes
  daily or weekly (docs, APIs, news)
| {
  class: leaf-rag
}

rag-reindex: |md
  ## RAG + Periodic Re-index
  Best when: data updates monthly
  (product catalogs, policies, manuals)
| {
  class: leaf-rag
}

d2 -> rag: "Hours / Days" {
  style: {
    stroke: "#4ade80"
    stroke-width: 2
    font-color: "#4ade80"
    font-size: 12
  }
}

d2 -> rag-reindex: "Weeks / Months" {
  style: {
    stroke: "#4ade80"
    stroke-width: 2
    font-color: "#4ade80"
    font-size: 12
  }
}

# NO branch - no external knowledge
d3: "Need to change model\nbehavior or style?" {
  class: decision
}

d1 -> d3: "No" {
  style: {
    stroke: "#f472b6"
    stroke-width: 2
    font-color: "#f472b6"
    font-size: 13
    bold: true
  }
}

# Fine-tuning branch
ft: |md
  ## Fine-Tuning
  Best when: custom tone, format,
  or domain-specific reasoning needed
| {
  class: leaf-ft
}

d3 -> ft: "Yes" {
  style: {
    stroke: "#f472b6"
    stroke-width: 2
    font-color: "#f472b6"
    font-size: 12
  }
}

# Prompt engineering branch
pe: |md
  ## Prompt Engineering
  Best when: base model capability
  is sufficient, just needs guidance
| {
  class: leaf-pe
}

d3 -> pe: "No" {
  style: {
    stroke: "#38bdf8"
    stroke-width: 2
    font-color: "#38bdf8"
    font-size: 12
  }
}

# Hybrid path
hybrid: |md
  ## Hybrid: RAG + Fine-Tuning
  Best when: custom behavior AND
  live data (e.g. domain-expert chatbot
  over company knowledge base)
| {
  class: leaf-hybrid
}

ft -> hybrid: "Also need live data?" {
  style: {
    stroke: "#ffb800"
    stroke-width: 2
    stroke-dash: 5
    font-color: "#ffb800"
    font-size: 12
  }
}

rag -> hybrid: "Also need custom behavior?" {
  style: {
    stroke: "#ffb800"
    stroke-width: 2
    stroke-dash: 5
    font-color: "#ffb800"
    font-size: 12
  }
}

# Cost badges
cost-rag: "0.01-0.05 per query" {
  class: badge
}

cost-ft: "5-100+ to train" {
  class: badge
}

cost-pe: "Free (just prompts)" {
  class: badge
}

rag -> cost-rag: {
  style: {
    stroke: "#8a8aa8"
    stroke-dash: 3
  }
}

ft -> cost-ft: {
  style: {
    stroke: "#8a8aa8"
    stroke-dash: 3
  }
}

pe -> cost-pe: {
  style: {
    stroke: "#8a8aa8"
    stroke-dash: 3
  }
}
